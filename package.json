{
  "name": "partysongs",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"pnpm run dev:server\" \"pnpm run dev:web\"",
    "dev:server": "pnpm --filter @partysongs/server dev",
    "dev:web": "pnpm --filter @partysongs/web dev",
    "build": "pnpm -r run build",
    "start": "pnpm --filter @partysongs/server start",
    "typecheck": "pnpm -r run typecheck"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
